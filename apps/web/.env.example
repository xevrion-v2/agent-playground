# =============================================================================
# TaskFlow Web — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp apps/web/.env.example apps/web/.env
# Next.js automatically loads .env.local and .env files.
# =============================================================================

# ----- API -----
NEXT_PUBLIC_API_URL="http://localhost:4000"   # Backend API base URL (prefixed with NEXT_PUBLIC_ for client access)

# ----- Authentication -----
NEXTAUTH_URL="http://localhost:3000"           # Base URL for NextAuth.js
NEXTAUTH_SECRET="change-me-to-a-random-secret" # NextAuth.js secret

# ----- OAuth Providers (NextAuth.js) -----
GOOGLE_CLIENT_ID=""                             # Google OAuth 2.0 client ID
GOOGLE_CLIENT_SECRET=""                         # Google OAuth 2.0 client secret
GITHUB_CLIENT_ID=""                             # GitHub OAuth App client ID
GITHUB_CLIENT_SECRET=""                         # GitHub OAuth App client secret

# ----- Stripe (client-side) -----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""           # Stripe publishable key

# ----- Feature Flags -----
NEXT_PUBLIC_ENABLE_BILLING="false"              # Enable billing features
NEXT_PUBLIC_ENABLE_MESSAGING="true"             # Enable messaging features

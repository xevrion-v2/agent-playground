# TaskFlow Web Frontend Environment Variables Example

# API Connection
# The base URL of the TaskFlow Express API backend.
# Ensure this matches the PORT configured on the backend (default http://localhost:4000).
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Payments client-side configuration
# Stripe publishable API key for checkout flows.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace_with_your_actual_stripe_publishable_key"

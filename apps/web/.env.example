# === Web App Environment Variables ===
# Copy this file to .env and fill in your values

# API server URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# NextAuth.js configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-strong-random-string

# OAuth - Google
GOOGLE_CLIENT_ID=replace-with-your-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-your-google-client-secret

# OAuth - GitHub
GITHUB_CLIENT_ID=replace-with-your-github-client-id
GITHUB_CLIENT_SECRET=replace-with-your-github-client-secret

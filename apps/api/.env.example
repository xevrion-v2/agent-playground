# TaskFlow API Environment Variables Example

# Server configuration
PORT=4000

# Database connection URL (PostgreSQL)
# Prisma client will use this to connect to the PostgreSQL database instance.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskflow?schema=public"

# Authentication configuration
# JWT secret token used for signing and verifying JSON Web Tokens.
# Generate a secure secret using `openssl rand -base64 32` for production.
JWT_SECRET="your_jwt_secret_key_change_in_production"

# Payments configuration (Stripe integration placeholder)
# Stripe API credentials for backend payment workflows.
STRIPE_SECRET_KEY="sk_test_replace_with_your_actual_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_replace_with_your_actual_stripe_webhook_secret"

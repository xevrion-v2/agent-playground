# === API Server Environment Variables ===
# Copy this file to .env and fill in your values

# Server port
PORT=4000

# Database connection string
DATABASE_URL=postgresql://localhost:5432/agent_playground

# JWT secret for signing tokens (change this in production!)
JWT_SECRET=replace-with-a-strong-random-string

# OAuth - Google
GOOGLE_CLIENT_ID=replace-with-your-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-your-google-client-secret

# Stripe payments
STRIPE_SECRET_KEY=replace-with-your-stripe-secret-key

# File uploads directory
UPLOAD_DIR=./uploads

# Maximum file size in MB
MAX_FILE_SIZE_MB=10

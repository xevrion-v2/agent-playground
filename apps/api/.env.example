# =============================================================================
# TaskFlow API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp apps/api/.env.example apps/api/.env
# =============================================================================

# ----- Server -----
PORT=4000                          # API server port
NODE_ENV=development               # development | production | test

# ----- Database (Prisma) -----
DATABASE_URL="postgresql://user:password@localhost:5432/taskflow?schema=public"

# ----- Authentication -----
JWT_SECRET="change-me-to-a-random-secret"   # HS256 secret for signing JWTs
JWT_EXPIRES_IN="15m"                         # Access token expiry
JWT_REFRESH_EXPIRES_IN="7d"                  # Refresh token expiry

# ----- OAuth (optional) -----
GOOGLE_CLIENT_ID=""                 # Google OAuth 2.0 client ID
GOOGLE_CLIENT_SECRET=""             # Google OAuth 2.0 client secret
GITHUB_CLIENT_ID=""                 # GitHub OAuth App client ID
GITHUB_CLIENT_SECRET=""             # GitHub OAuth App client secret

# ----- Payments (Stripe) -----
STRIPE_SECRET_KEY=""                # Stripe secret key (sk_live_... or sk_test_...)
STRIPE_WEBHOOK_SECRET=""            # Stripe webhook signing secret

# ----- File Uploads -----
UPLOAD_PROVIDER="local"             # local | s3
UPLOAD_DIR="./uploads"              # Local upload directory (when UPLOAD_PROVIDER=local)
AWS_S3_BUCKET=""                    # S3 bucket name (when UPLOAD_PROVIDER=s3)
AWS_REGION=""                       # S3 region
AWS_ACCESS_KEY_ID=""                # AWS access key
AWS_SECRET_ACCESS_KEY=""            # AWS secret key

# ----- Email -----
SMTP_HOST=""                        # SMTP server hostname
SMTP_PORT=587                       # SMTP port
SMTP_USER=""                        # SMTP username
SMTP_PASS=""                        # SMTP password
EMAIL_FROM="noreply@taskflow.dev"   # Sender address

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW_MS=60000          # Window duration in milliseconds
RATE_LIMIT_MAX_REQUESTS=100         # Max requests per window per IP

# ----- CORS -----
CORS_ORIGIN="http://localhost:3000" # Allowed origin (comma-separated for multiple)

# ----- Logging -----
LOG_LEVEL="info"                    # error | warn | info | debug

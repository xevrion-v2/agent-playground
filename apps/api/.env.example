# TaskFlow API Environment Variables

# Server port (default: 4000)
PORT=4000

# Database (PostgreSQL via Prisma)
DATABASE_URL=postgresql://user:***@localhost:5432/taskflow

# Auth secret for JWT tokens
JWT_SECRET=your-s...e
# Stripe payments (optional)
STRIPE_SECRET_KEY=*** File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
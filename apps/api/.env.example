# ─── TaskFlow API Environment Variables ───────────────────
#
# Copy this file to .env and fill in the values for local development.
# All variables are required unless marked (optional).

# ── Server ────────────────────────────────────────────────
# Port the Express API server listens on (default: 4000)
PORT=4000

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection URL used by Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskflow

# ── Auth ──────────────────────────────────────────────────
# Secret key for signing JWT access tokens (use a long random string)
JWT_SECRET=change-me-to-a-random-secret

# Secret key for signing JWT refresh tokens
JWT_REFRESH_SECRET=change-me-to-another-random-secret

# Access token expiry duration (e.g. 15m, 1h)
JWT_ACCESS_EXPIRY=15m

# Refresh token expiry duration (e.g. 7d, 30d)
JWT_REFRESH_EXPIRY=7d

# ── OAuth (optional) ──────────────────────────────────────
# Google OAuth client ID for social login
# GOOGLE_CLIENT_ID=

# Google OAuth client secret
# GOOGLE_CLIENT_SECRET=

# OAuth callback base URL (e.g. http://localhost:4000)
# OAUTH_CALLBACK_BASE=http://localhost:4000

# ── Stripe Payments (optional) ────────────────────────────
# Stripe secret key for payment processing
# STRIPE_SECRET_KEY=

# Stripe webhook signing secret
# STRIPE_WEBHOOK_SECRET=

# ── File Uploads (optional) ───────────────────────────────
# Maximum upload file size (e.g. 5mb)
# UPLOAD_MAX_SIZE=5mb

# Upload storage backend: local | s3
# UPLOAD_BACKEND=local

# Local upload directory (when UPLOAD_BACKEND=local)
# UPLOAD_DIR=./uploads

# ── CORS ──────────────────────────────────────────────────
# Allowed origin for CORS (default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────
# Max requests per window per IP (default: 100)
# RATE_LIMIT_MAX=100

# Rate limit window duration in minutes (default: 15)
# RATE_LIMIT_WINDOW_MIN=15

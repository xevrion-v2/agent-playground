# ============================================================
# TaskFlow — Environment Variables
# ============================================================
# Copy this file to .env (in each app/package) and fill in real values.
# See README.md for workspace structure.

# --- Database (packages/db + apps/api) ---
# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/taskflow"

# --- API Server (apps/api) ---
# Listening port (default: 4000)
PORT=4000

# --- Auth (apps/api) ---
# Secret used to sign JWT access tokens
JWT_SECRET="change-me-to-a-random-string"

# Secret used to sign JWT refresh tokens
JWT_REFRESH_SECRET="change-me-to-another-random-string"

# --- Stripe Payments (apps/api) ---
# Stripe secret key for server-side payment processing
STRIPE_SECRET_KEY="sk_test_..."

# Stripe webhook signing secret for verifying events
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Web App (apps/web) ---
# Canonical URL of the deployed frontend (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- External Integrations ---
# Optional: OAuth provider credentials
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

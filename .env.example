# ===========================================
# TaskFlow — Local Environment Variables
# ===========================================
#
# Copy this file to .env and fill in the values
# for your local development setup.
#
#   cp .env.example .env
#
# All variables have sensible defaults for
# local development. Only override what you
# need to change.

# ── API Server ─────────────────────────────

# Port the Express API listens on.
# Default: 4000
PORT=4000

# ── Database (Prisma) ──────────────────────
#
# When a DATABASE_URL is configured, the API
# connects to the specified database.
# Default (not set): in-memory / mock mode.
#
# DATABASE_URL=postgresql://user:password@localhost:5432/taskflow

# ── Authentication ─────────────────────────
#
# JWT secret used for signing and verifying
# auth tokens. Generate a random string for
# local development:
#
#   openssl rand -hex 32
#
# Default (not set): auth routes return mock
# responses.
#
# JWT_SECRET=your-random-secret-here

# ── Frontend (apps/web) ────────────────────
#
# The web app reads NEXT_PUBLIC_API_URL to
# know where the backend lives.
# Default: http://localhost:4000
#
# NEXT_PUBLIC_API_URL=http://localhost:4000

# =============================================================================
# TaskFlow — Environment Variables Reference
# =============================================================================
# Copy this file to .env (or the appropriate per-app .env file) and fill in
# your local values.  Never commit .env files to version control.
#
#   cp .env.example .env
#
# === Workspace layout ===
# apps/api     — Express.js backend with layered REST API
# apps/web     — Next.js 14 App Router frontend
# packages/db  — Prisma schema and database utilities
# packages/ui  — Shared UI component library
# =============================================================================

# ---------------------------------------------------------------------------
# API (apps/api)
# ---------------------------------------------------------------------------

# Port the Express server listens on.
# Used in: apps/api/src/index.ts
# Default:  4000
PORT=4000

# Node environment.  Controls error-response behaviour (stack traces are
# included when NODE_ENV is NOT "production").
# Used in: apps/api/src/utils/apiError.ts
# Accepts: development | production | test
NODE_ENV=development

# ---------------------------------------------------------------------------
# Database (packages/db)
# ---------------------------------------------------------------------------

# Prisma datasource connection string (PostgreSQL).
# Used in: packages/db/prisma/schema.prisma
# Format:  postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskflow?schema=public

# ---------------------------------------------------------------------------
# Web / Next.js (apps/web)
# ---------------------------------------------------------------------------

# URL of the backend API, exposed to the browser.
# Next.js convention: prefix with NEXT_PUBLIC_ to make it available on the
# client side.  The web app is scaffolded but routes are not yet wired.
# NEXT_PUBLIC_API_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Authentication (planned — JWT / OAuth)
# ---------------------------------------------------------------------------

# Secret used to sign and verify JSON Web Tokens.
# Generate one with: openssl rand -base64 64
# JWT_SECRET=change-me-to-a-random-secret

# OAuth provider credentials (example for GitHub; add others as needed).
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Payments (planned — Stripe)
# ---------------------------------------------------------------------------

# Stripe API keys — one for the server-side SDK, one for the frontend.
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook signing secret.
# STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# File Uploads (planned — S3-compatible storage)
# ---------------------------------------------------------------------------

# AWS / S3-compatible object-store credentials.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=taskflow-uploads

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------

# Comma-separated list of origins allowed by CORS (API).
# Defaults to http://localhost:3000 when not set.
# CORS_ORIGINS=http://localhost:3000,http://localhost:4000

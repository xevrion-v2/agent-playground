# =============================================================================
# Agent Playground - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

## Application
PORT=3000                          # API server port (default: 3000)
NODE_ENV=development                # Environment: development | production | test

## Database
DATABASE_URL=postgresql://user:pass@localhost:5432/agent-playground
                                   # PostgreSQL connection string
                                   # Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE

## Authentication
JWT_SECRET=change-me-to-a-random-secret
                                   # JWT signing secret (generate with: openssl rand -hex 32)
JWT_EXPIRES_IN=7d                  # Token expiry duration

## Rate Limiting
RATE_LIMIT_WINDOW_MS=60000         # Rate limit window in milliseconds (default: 1 minute)
RATE_LIMIT_MAX_REQUESTS=100        # Max requests per window per IP

## Logging
LOG_LEVEL=debug                    # Log level: error | warn | info | debug

# ========================================
# TaskFlow — Environment Variables
# ========================================
# Copy this file to .env and fill in your local values.

# ---- Database ----
# PostgreSQL connection string (used by Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/taskflow"

# ---- API Server ----
# Port for the Express API (default: 4000)
PORT=4000

# ---- Authentication ----
# Secret key for signing JWT access/refresh tokens
JWT_SECRET="change-me-in-production"

# ---- Web App ----
# Base URL of the Next.js frontend (used for CORS)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ---- Optional Services ----
# Redis URL for caching (leave empty to skip)
REDIS_URL=""

# GitHub token for bounty automation (optional)
GITHUB_TOKEN=""

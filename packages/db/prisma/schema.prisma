// TaskFlow Prisma Schema — Core domain models for a task management SaaS platform
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Represents a registered user in the TaskFlow platform. Users can be clients (posting tasks) or freelancers (completing tasks).
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  jobs      Job[]
  proposals Proposal[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Job {
  id          String     @id @default(cuid())
  updatedAt DateTime @updatedAt
}

// Represents a task posted by a client. Freelancers can submit proposals to complete the task.
model Task {
  id          String   @id @default(cuid())
  title       String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Proposal {
  id        String   @id @default(cuid())
  summary   String
  updatedAt   DateTime @updatedAt
}

// Represents a freelancer's bid/proposal to complete a specific task. Linked to both the task and the proposing user.
model Proposal {
  id          String   @id @default(cuid())
  taskId      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
  updatedAt   DateTime @updatedAt
}

// Represents a payment transaction between a client and freelancer for a completed task. Integrates with Stripe for processing.
model Payment {
  id        String   @id @default(cuid())
  taskId    String
  updatedAt DateTime @updatedAt
}

// Represents a review left by one user for another after task completion. Part of the reputation system.
model Review {
  id        String   @id @default(cuid())
  taskId    String
  updatedAt DateTime @updatedAt
}

// Represents a direct message sent between two users within the platform. Supports the built-in messaging system.
model Message {
  id         String   @id @default(cuid())
  senderId   String
  updatedAt   DateTime @updatedAt
}

// Represents a task category for organizing and filtering tasks (e.g., Web Development, Design, Writing).
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  updatedAt DateTime @updatedAt
}

// Represents a skill that users can add to their profiles and that can be associated with tasks for matching.
model Skill {
  id        String   @id @default(cuid())
  name      String   @unique

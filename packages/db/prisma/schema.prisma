generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url     = env("DATABASE_URL")
}

// Model for User entity
// Represents a platform user with profile information and auth details
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password    String?
  name      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks     Task[]
  proposals Proposal[]
  reviews   Review[]
  messages  Message[]
}

// Model for Task entity
// Represents a task created by a user in the TaskFlow system
model Task {
  id          String   @id @default(cuid())
  title       String
  description  String?
  ownerId      String
  owner       User     @relation(fields: [ownerId], references: [id])
  categoryId    String?
  category     Category?
  skills      Skill[]
  proposals   Proposal[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// Model for Proposal entity
// Represents a proposal made by a freelancer for a task
model Proposal {
  id        String   @id @default(cuid())
  taskId     String
  task      Task     @relation(fields: [taskId], references: [id])
  proposerId String
  proposer  User     @relation(fields: [proposerId], references: [id])
  content   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Model for Payment entity
// Represents a payment transaction between users
model Payment {
  id        String   @id @default(cuid())
  taskId     String
  task      Task     @relation(fields: [taskId], references: [id])
  payerId   String
  payer     User     @relation(fields: [payerId], references: [id])
  amount    Float
  status    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Model for Review entity
// Represents a review given by a user for a completed task
model Review {
  id        String   @id @default(cuid())
  taskId     String
  task      Task     @relation(fields: [taskId], references: [id])
  reviewerId  String
  reviewer    User     @relation(fields: [reviewerId], references: [id])
  rating     Int
  comment    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Model for Message entity
// Represents a message between users in the messaging system
model Message {
  id        String   @id @default(cuid())
  senderId   String
  sender     User     @relation(fields: [senderId], references: [id])
  content    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Model for Category entity
// Represents a task category for organizing tasks
model Category {
  id    String @id @default(cuid())
  name  String @unique
  tasks Task[]
}

// Model for Skill entity
// Represents a skill that can be associated with tasks and users
model Skill {
  id   String @id @default(cuid())
  name String @unique
  tasks Task[]
}
}

// Prisma schema for TaskFlow - a task management SaaS platform
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Represents a user in the TaskFlow system, including both clients and freelancers
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  jobs      Job[]
  proposals Proposal[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Job {
  id          String     @id @default(cuid())
  updatedAt DateTime @updatedAt
}

// Represents a task posted by a client that freelancers can propose to complete
model Task {
  id          String   @id @default(cuid())
  title       String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Proposal {
  id        String   @id @default(cuid())
  summary   String
  amount    Decimal?
  status    String   @default("pending")
  updatedAt   DateTime @updatedAt
}

// Represents a freelancer's proposal to complete a specific task
model Proposal {
  id       String @id @default(cuid())
  taskId   String
}
  updatedAt DateTime @updatedAt
}

// Represents a payment transaction between a client and freelancer for a completed task
model Payment {
  id        String   @id @default(cuid())
  taskId    String
  updatedAt DateTime @updatedAt
}

// Represents a review left by a user for another user after task completion
model Review {
  id        String   @id @default(cuid())
  reviewerId String
  updatedAt DateTime @updatedAt
}

// Represents a message sent between users within the TaskFlow messaging system
model Message {
  id        String   @id @default(cuid())
  senderId   String
  updatedAt DateTime @updatedAt
}

// Represents a category for organizing tasks (e.g., Web Development, Design)
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  tasks     Task[]
}

// Represents a skill that freelancers can have and tasks may require
model Skill {
  id        String   @id @default(cuid())
  name      String   @unique

// Prisma schema for TaskFlow - a task management SaaS platform
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Represents a user in the TaskFlow platform. Users can be clients who post tasks or freelancers who complete them.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  jobs      Job[]
  proposals Proposal[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Job {
  id          String     @id @default(cuid())
  updatedAt DateTime @updatedAt
}

/// Represents a task posted by a client. Tasks are the core unit of work in the TaskFlow domain and can receive proposals from freelancers.
model Task {
  id          String   @id @default(cuid())
  title       String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Proposal {
  id        String   @id @default(cuid())
  summary   String
  amount    Decimal?
  updatedAt   DateTime @updatedAt
}

/// Represents a proposal submitted by a freelancer to work on a task. Proposals connect freelancers with tasks they want to complete.
model Proposal {
  id       String @id @default(cuid())
  taskId   String
  updatedAt DateTime @updatedAt
}
  updatedAt DateTime @updatedAt
}

/// Represents a payment transaction for a completed task. Payments facilitate the financial exchange between clients and freelancers.
model Payment {
  id     String @id @default(cuid())
  taskId String
  updatedAt DateTime @updatedAt
}

/// Represents a review left by a user for another user after task completion. Reviews help build trust and reputation in the platform.
model Review {
  id      String @id @default(cuid())
  taskId  String
  updatedAt DateTime @updatedAt
}

/// Represents a message sent between users in the TaskFlow messaging system. Messages enable communication between clients and freelancers.
model Message {
  id       String @id @default(cuid())
  senderId String
  updatedAt DateTime @updatedAt
}

/// Represents a category for organizing tasks. Categories help users discover and filter tasks by type of work.
model Category {
  id    String @id @default(cuid())
  name  String @unique
  updatedAt DateTime @updatedAt
}

/// Represents a skill that users can associate with their profiles. Skills help match freelancers with relevant tasks.
model Skill {
  id    String @id @default(cuid())
  name  String @unique

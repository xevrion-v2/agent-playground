generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  url      = env("DATABASE_URL")
}

/// Represents a user in the TaskFlow platform. Users can be clients or freelancers and can participate in tasks, proposals, and messaging.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  jobs      Job[]
  proposals Proposal[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Job {
  id          String     @id @default(cuid())
  updatedAt DateTime @updatedAt
}

/// Represents a task posted by a client. Freelancers can view tasks and submit proposals to complete them.
model Task {
  id          String   @id @default(cuid())
  title       String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Proposal {
  id        String   @id @default(cuid())
  summary   String
  updatedAt   DateTime @updatedAt
}

/// Represents a freelancer's bid or offer to complete a specific task. Proposals include pricing and timeline details.
model Proposal {
  id          String   @id @default(cuid())
  taskId      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
  updatedAt   DateTime @updatedAt
}

/// Represents a financial transaction between a client and freelancer for a completed task. Integrates with Stripe for processing.
model Payment {
  id        String   @id @default(cuid())
  amount    Decimal
  updatedAt DateTime @updatedAt
}

/// Represents feedback and rating left by one user for another after a task is completed. Helps build trust in the platform.
model Review {
  id        String   @id @default(cuid())
  rating    Int
  updatedAt DateTime @updatedAt
}

/// Represents a direct message sent between two users on the platform. Supports real-time communication for task coordination.
model Message {
  id        String   @id @default(cuid())
  content   String
  updatedAt DateTime @updatedAt
}

/// Represents a category used to classify and filter tasks. Helps freelancers discover relevant work and clients organize postings.
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  updatedAt DateTime @updatedAt
}

/// Represents a skill that users can add to their profiles. Used for matching freelancers with relevant tasks and improving search discoverability.
model Skill {

// Prisma schema for TaskFlow - a task management SaaS platform
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Represents a user in the system. Can be a client (posts tasks) or freelancer (completes tasks).
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  jobs      Job[]
  proposals Proposal[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Job {
  id          String     @id @default(cuid())
  updatedAt DateTime @updatedAt
}

// Represents a task posted by a client. Freelancers can submit proposals to complete it.
model Task {
  id          String   @id @default(uuid())
  title       String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Proposal {
  id        String   @id @default(cuid())
  summary   String
  amount    Decimal?
  updatedAt   DateTime @updatedAt
}

// Represents a freelancer's bid/proposal to complete a specific task.
model Proposal {
  id          String   @id @default(uuid())
  taskId      String
  updatedAt DateTime @updatedAt
}
  updatedAt   DateTime @updatedAt
}

// Represents a payment transaction between a client and freelancer for a completed task.
model Payment {
  id        String   @id @default(uuid())
  taskId    String
  updatedAt DateTime @updatedAt
}

// Represents a review left by a client for a freelancer after task completion.
model Review {
  id        String   @id @default(uuid())
  taskId    String
  updatedAt DateTime @updatedAt
}

// Represents a direct message sent between two users in the platform.
model Message {
  id         String   @id @default(uuid())
  senderId   String
  updatedAt  DateTime @updatedAt
}

// Represents a task category used to organize and filter tasks.
model Category {
  id          String @id @default(uuid())
  name        String @unique
  tasks       Task[]
}

// Represents a skill that freelancers can add to their profiles and clients can require for tasks.
model Skill {
  id          String @id @default(uuid())
  name        String @unique

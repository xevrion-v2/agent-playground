// Prisma schema for TaskFlow — a task management SaaS platform connecting clients and freelancers
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core user accounts with role-based access (client, freelancer, admin)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  jobs      Job[]
  proposals Proposal[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Job {
  id          String     @id @default(cuid())
  updatedAt DateTime @updatedAt
}

// Tasks posted by clients; freelancers submit proposals to complete them
model Task {
  id          String   @id @default(cuid())
  title       String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Proposal {
  id        String   @id @default(cuid())
  summary   String
  amount    Decimal?
  status    String   @default("pending")
  updatedAt   DateTime @updatedAt
}

// Proposals submitted by freelancers in response to tasks
model Proposal {
  id          String   @id @default(cuid())
  taskId      String
}
  updatedAt   DateTime @updatedAt
}

// Payment records for task milestones and escrow tracking
model Payment {
  id        String   @id @default(cuid())
  taskId    String
  updatedAt DateTime @updatedAt
}

// Reviews and ratings exchanged between clients and freelancers after task completion
model Review {
  id        String   @id @default(cuid())
  taskId    String
  updatedAt DateTime @updatedAt
}

// Direct messages between users within the platform
model Message {
  id         String   @id @default(cuid())
  senderId   String
  updatedAt  DateTime @updatedAt
}

// Task categories for organizing and filtering tasks
model Category {
  id          String @id @default(cuid())
  name        String @unique
  tasks       Task[]
}

// Skills that freelancers can list and clients can require for tasks
model Skill {
  id          String @id @default(cuid())
  name        String @unique

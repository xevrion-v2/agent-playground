# Database
# Prisma uses this to connect to your PostgreSQL database.
# Replace the placeholders with your actual values.
DATABASE_URL="postgresql://user:***@localhost:5432/taskflow?schema=public"

# (Optional) Direct database connection for migration tools.
# If not set, Prisma falls back to DATABASE_URL.
SHADOW_DATABASE_URL="postgresql://user:***@localhost:5432/taskflow_shadow?schema=public"

# =============================================================================
# TaskFlow Database Package — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp packages/db/.env.example packages/db/.env
# =============================================================================

# ----- Database Connection -----
DATABASE_URL="postgresql://user:password@localhost:5432/taskflow?schema=public"
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Supported providers: PostgreSQL, MySQL, SQLite, SQL Server
# See: https://www.prisma.io/docs/reference/database-reference/connection-urls
